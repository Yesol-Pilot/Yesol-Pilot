        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/images/**": true,
        "**/assets/**": true,
        "**/backups/**": true,
        "**/_backup/**": true,
        "**/.agent/**": true,
        "**/.gemini/**": true
